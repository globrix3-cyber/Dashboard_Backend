# ─────────────────────────────────────────────────────────────────────────────
# Globrixa Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

PORT=8000

# PostgreSQL (Aiven or any Postgres provider)
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Redis (Railway Redis, Upstash, or local)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string

# Frontend URL (for CORS) — no trailing slash
FRONTEND_URL=http://localhost:5173

# Gmail SMTP — used to email password-reset PINs (use a 16-char Gmail "app password",
# not your normal account password: https://myaccount.google.com/apppasswords)
EMAIL_USER=youraddress@gmail.com
EMAIL_APP_PASSWORD=replace_with_a_16_char_gmail_app_password

# Logging
LOG_LEVEL=info
